# .env.template (DO NOT commit real secrets; this is a template)
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_KEY=<your-supabase-key>

# LLM (Groq)
USE_LLM=True
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=<your-groq-key>

# Watson (optional)
USE_WATSON=False
WATSON_APIKEY=
WATSON_URL=
ASSISTANT_ID=
ENVIRONMENT_ID=

# Local & app settings
LOCAL_SAVE_PATH=local_progress.json
USER_ID=
BATCH_SIZE=3
SINGLE_FILE=Student Mental Health.csv

# Flask webhook
FLASK_WEBHOOK_ENABLED=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
